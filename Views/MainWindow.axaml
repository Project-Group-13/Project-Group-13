<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:project.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="project.Views.MainWindow"
        Icon="/Assets/avalonia-logo.ico"
        Title="HeatItOn Optimization System"
        x:CompileBindings="False"> <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <TabControl>
        <TabItem Header="Units">
            <StackPanel Margin="20" Spacing="10">
                <StackPanel.DataContext>
                    <vm:UnitsViewModel/>
                </StackPanel.DataContext>

                <TextBlock Text="Production Unit Information" FontSize="15" FontWeight="Bold"/>

                <TextBlock Text="Select a Unit:"/>
                <ComboBox ItemsSource="{Binding AllUnits}" 
                          SelectedItem="{Binding SelectedUnit}"
                          Width="250">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Separator Margin="0,10"/>

                <StackPanel Spacing="5" IsVisible="{Binding SelectedUnit, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock Text="Szstem" FontWeight="Bold" Foreground="Blue"/>
                    
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Name: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedUnit.Name}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Max Heat: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedUnit.MaxHeat}"/>
                        <TextBlock Text=" MW"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Production Cost: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedUnit.ProductionCost}"/>
                        <TextBlock Text=" DKK/MWh"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </TabItem>

        <TabItem Header="Optimization">
            <TextBlock Text="The optimization dashboard will be implemented here." Margin="20"/>
        </TabItem>
    </TabControl>
</Window>