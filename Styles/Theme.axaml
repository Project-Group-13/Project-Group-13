<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Global typography and colors -->
  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="#111"/>
  </Style>

  <!-- Buttons -->
  <Style Selector="Button">
    <Setter Property="Background" Value="#F2F2F6"/>
    <Setter Property="Foreground" Value="#111"/>
    <Setter Property="BorderBrush" Value="#D0D0D8"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="CornerRadius" Value="8"/>
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="#E5E5EA"/>
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="Background" Value="#DDE0E9"/>
  </Style>

  <!-- Combobox styling -->
  <Style Selector="ComboBox">
    <Setter Property="Background" Value="#F2F2F6"/>
    <Setter Property="Foreground" Value="#111"/>
    <Setter Property="BorderBrush" Value="#D0D0D8"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
  </Style>

  <Style Selector="ComboBoxItem">
    <Setter Property="Background" Value="#FFFFFF"/>
    <Setter Property="Foreground" Value="#111"/>
    <Setter Property="Padding" Value="8,4"/>
  </Style>

  <Style Selector="ComboBoxItem:pointerover">
    <Setter Property="Background" Value="#E5E5EA"/>
  </Style>

  <Style Selector="ComboBoxItem:selected">
    <Setter Property="Background" Value="#DDE0E9"/>
    <Setter Property="Foreground" Value="#111"/>
  </Style>

  <!-- Tabs -->
  <Style Selector="TabControl">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>

  <Style Selector="TabItem">
    <Setter Property="Background" Value="#F7F7F8"/>
    <Setter Property="Foreground" Value="#222"/>
    <Setter Property="Padding" Value="14,8"/>
    <Setter Property="Margin" Value="0,0,8,0"/>
    <Setter Property="CornerRadius" Value="12"/>
  </Style>

  <Style Selector="TabItem:selected">
    <Setter Property="Background" Value="#FFFFFF"/>
    <Setter Property="BorderBrush" Value="#E0E0E3"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Foreground" Value="#111"/>
  </Style>

</Styles>